# Example file.
# The `.tf.example` extension prevents Terraform from loading it automatically.
#
# Purpose:
# - show how to attach the EKS module to the VPC created by `vpc.tf`
# - use node private subnets as EKS node subnets
#
# Before using this example in a live environment, adjust the cluster version,
# instance types, and allowed access CIDRs to match your team standards.

# locals {
#   eks_cluster_name = "${local.name_prefix}-eks"
#
#   eks_node_subnet_ids = [
#     for key in sort(keys(module.vpc.node_private_subnet_ids)) :
#     module.vpc.node_private_subnet_ids[key]
#   ]
# }
#
# module "eks" {
#   source = "../../modules/eks"
#
#   name                             = local.eks_cluster_name
#   cluster_version                  = "1.30"
#   vpc_id                           = module.vpc.id
#   subnet_ids                       = local.eks_node_subnet_ids
#   kubernetes_service_ipv4_cidr     = "172.20.0.0/16"
#   endpoint_public_access           = true
#   endpoint_private_access          = true
#   endpoint_public_access_cidrs     = ["0.0.0.0/0"]
#   cluster_log_types                = ["api", "audit", "authenticator"]
#   cloudwatch_log_retention_in_days = 7
#   node_group_name                  = "default"
#   node_group_instance_types        = ["t3.medium"]
#   node_group_capacity_type         = "ON_DEMAND"
#   node_group_disk_size             = 20
#   node_group_desired_size          = 1
#   node_group_min_size              = 1
#   node_group_max_size              = 2
#   tags                             = local.common_tags
# }
#
# Notes:
# - If you need ALB Controller subnet discovery tags, build them in `vpc.tf`
#   via `local.vpc_subnet_tags` and pass them as `subnet_tags`.
# - In production, it is safer to restrict `endpoint_public_access_cidrs`
#   to fixed company IP ranges.
