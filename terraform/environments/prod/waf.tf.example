# 예시 파일입니다.
# 확장자가 `.tf.example` 이므로 Terraform이 읽지 않습니다.
#
# 목적:
# - ALB 앞단에 WAFv2 Web ACL 을 붙이는 기본 예시
#
# 참고:
# - 아래 예시는 REGIONAL scope 기준이므로 ALB 보호 예시입니다.
# - CloudFront 보호를 하려면 scope = "CLOUDFRONT" 와 us-east-1 provider 구성이 별도로 필요합니다.
# - resource_arn 은 실제 ALB ARN 으로 교체해야 합니다.

# resource "aws_wafv2_web_acl" "alb" {
