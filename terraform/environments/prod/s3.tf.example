# -----------------------------------------------------------------------------
# Example 3: non-static buckets
# -----------------------------------------------------------------------------
#
# If the bucket purpose is not "frontend static hosting", do not force-fit it
# into ../../modules/s3. Create a separate file and model the bucket according
# to its job.
#
# Suggested split by purpose:
# - s3-uploads.tf   : application/user upload buckets
# - s3-logs.tf      : ALB, CloudFront, or app log buckets
# - s3-backups.tf   : backup/archive buckets
# - s3-data.tf      : data exchange or internal storage buckets
#
# Minimal sketch for a non-static bucket:
#
# resource "aws_s3_bucket" "app_uploads" {
#   bucket = "airline-app-uploads"
#
#   tags = merge(local.common_tags, {
#     Name    = "airline-app-uploads"
#     Purpose = "uploads"
#   })
# }
#
# resource "aws_s3_bucket_versioning" "app_uploads" {
#   bucket = aws_s3_bucket.app_uploads.id
#
#   versioning_configuration {
#     status = "Enabled"
#   }
# }
#
# resource "aws_s3_bucket_server_side_encryption_configuration" "app_uploads" {
#   bucket = aws_s3_bucket.app_uploads.id
#
#   rule {
#     apply_server_side_encryption_by_default {
#       sse_algorithm = "AES256"
#     }
#   }
# }
#
# resource "aws_s3_bucket_public_access_block" "app_uploads" {
#   bucket = aws_s3_bucket.app_uploads.id
#
#   block_public_acls       = true
#   block_public_policy     = true
#   ignore_public_acls      = true
#   restrict_public_buckets = true
# }
