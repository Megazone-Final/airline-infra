# Example only.
# Terraform does not load this file because the extension is `.tf.example`.
#
# Important:
# The current ../../modules/s3 module is not a generic S3 bucket module.
# It creates a static hosting stack:
# - S3 bucket
# - versioning
# - server-side encryption
# - public access block
# - CloudFront OAC
# - CloudFront distribution
# - bucket policy for CloudFront access
#
# Use ../../modules/s3 only when the bucket is meant to serve a frontend/static site.
# Do not use it as-is for upload buckets, log buckets, backup buckets, or data buckets.
# Those should be modeled separately with plain aws_s3_* resources or a dedicated module.

# -----------------------------------------------------------------------------
# Example 1: one static site bucket
# -----------------------------------------------------------------------------
#
# module "frontend_main" {
#   source = "../../modules/s3"
#
#   name                = "${var.project_name}-${var.environment}-main"
#   bucket_name         = "airline-main-frontend"
#   aliases             = ["airline.example.com"]
#   acm_certificate_arn = var.main_frontend_certificate_arn
#   price_class         = "PriceClass_200"
#   enable_spa_routing  = true
#   tags                = local.common_tags
# }

