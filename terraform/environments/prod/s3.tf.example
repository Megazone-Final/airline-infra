# 예시 파일입니다.
# 확장자가 `.tf.example` 이므로 Terraform이 읽지 않습니다.
#
# 중요:
# 현재 ../../modules/s3 는 범용 S3 버킷 모듈이 아닙니다.
# 아래 리소스를 한 번에 만드는 "정적 웹 호스팅용" 모듈입니다.
# - S3 버킷
# - 버전 관리
# - 서버 측 암호화
# - Public Access Block
# - CloudFront OAC
# - CloudFront Distribution
# - CloudFront 전용 Bucket Policy
#
# 따라서 업로드 버킷, 로그 버킷, 백업 버킷, 데이터 보관 버킷에는
# 이 모듈을 그대로 쓰지 않는 편이 맞습니다.

# -----------------------------------------------------------------------------
# 예시 1: 정적 사이트 버킷 1개
# -----------------------------------------------------------------------------
#
# module "frontend_main" {
#   source = "../../modules/s3"
#
#   name                = "${local.name_prefix}-main"
#   bucket_name         = "s3-an2-airline-main-frontend"
#   aliases             = ["airline.example.com"]
#   acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/replace-me"
#   price_class         = "PriceClass_200"
#   enable_spa_routing  = true
#   tags                = local.common_tags
# }

# -----------------------------------------------------------------------------
# 예시 2: 정적 사이트 버킷 여러 개
# -----------------------------------------------------------------------------
#
# locals {
#   frontend_sites = {
#     main = {
#       bucket_name         = "s3-an2-airline-main-frontend"
#       aliases             = ["airline.example.com"]
#       acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/replace-me-main"
#       price_class         = "PriceClass_200"
#       enable_spa_routing  = true
#     }
#     admin = {
#       bucket_name         = "s3-an2-airline-admin-frontend"
#       aliases             = ["admin.airline.example.com"]
#       acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/replace-me-admin"
#       price_class         = "PriceClass_200"
#       enable_spa_routing  = true
#     }
#   }
# }
#
# module "frontend_sites" {
#   for_each = local.frontend_sites
#   source   = "../../modules/s3"
#
#   name                = "${local.name_prefix}-${each.key}"
#   bucket_name         = each.value.bucket_name
#   aliases             = each.value.aliases
#   acm_certificate_arn = each.value.acm_certificate_arn
#   price_class         = each.value.price_class
#   enable_spa_routing  = each.value.enable_spa_routing
#   tags                = local.common_tags
# }

# -----------------------------------------------------------------------------
# 예시 3: 비정적 버킷은 별도 리소스로 구성
# -----------------------------------------------------------------------------
#
# 로그, 업로드, 백업, 데이터 보관 버킷은 보통 아래처럼 용도별로 분리합니다.
# - s3-logs.tf
# - s3-uploads.tf
# - s3-backups.tf
# - s3-data.tf
#
# resource "aws_s3_bucket" "app_uploads" {
#   bucket = "s3-an2-airline-uploads"
#
#   tags = merge(local.common_tags, {
#     Name    = "s3-an2-airline-uploads"
#     Purpose = "uploads"
#   })
# }
#
# resource "aws_s3_bucket_versioning" "app_uploads" {
#   bucket = aws_s3_bucket.app_uploads.id
#
#   versioning_configuration {
#     status = "Enabled"
#   }
# }
#
# resource "aws_s3_bucket_server_side_encryption_configuration" "app_uploads" {
#   bucket = aws_s3_bucket.app_uploads.id
#
#   rule {
#     apply_server_side_encryption_by_default {
#       sse_algorithm = "AES256"
#     }
#   }
# }
#
# resource "aws_s3_bucket_public_access_block" "app_uploads" {
#   bucket = aws_s3_bucket.app_uploads.id
#
#   block_public_acls       = true
#   block_public_policy     = true
#   ignore_public_acls      = true
#   restrict_public_buckets = true
# }
